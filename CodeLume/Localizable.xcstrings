      }
    },
    "1. Click the download button to download the screen saver file to your desktop;" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. 点击下载按钮将屏保文件下载到您的桌面；"
          }
        }
      }
    },
    "2. Double-click the downloaded .saver file to install;" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "2. 双击已下载的.saver文件进行安装；"
          }
        }
      }
    },
    "3. Select your video file to set up;" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
