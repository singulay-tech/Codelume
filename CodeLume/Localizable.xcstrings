    "© 2025 CodeLume. All rights reserved." : {
      "extractionState" : "stale",
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "© 2025 码镜 保留所有权利。"
