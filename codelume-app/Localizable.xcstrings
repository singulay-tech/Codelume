    "• Use the AVKit framework to set regular videos as dynamic wallpapers, with no interactive support." : {
      "extractionState" : "stale",
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• 借助 AVkit 框架将普通视频设置为动态壁纸，不支持交互"
          }
        }
      }
    },
    "• Use the high-performance SpriteKit framework to render 2D interactive dynamic wallpapers" : {
      "extractionState" : "stale",
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• 借助高性能 SpriteKit 框架渲染2D 可交互动态壁纸"
          }
        }
      }
    },
    "• Use the SceneKit framework to create interactive 3D dynamic wallpapers with high resource consumption" : {
      "extractionState" : "stale",
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• 借助 SceneKit 框架实现可交互的3D动态壁纸，资源占用较高"
          }
        }
      }
    },
